<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgApp">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_toolbar">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbarAdd"
            style="@style/ToolbarStyle"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@null"
            app:title="Add Product"
            app:navigationIcon="@drawable/ic_refresh"/>
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Info card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#0D1565C0"
                android:layout_marginBottom="16dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:text="ℹ️  Paste the JioMart product URL and enter the coordinates of your location. The nearest store will be auto-selected."
                    android:textColor="@color/trialText"
                    android:textSize="13sp"
                    android:lineSpacingExtra="3dp"/>
            </androidx.cardview.widget.CardView>

            <!-- Emoji picker -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Select Emoji"
                android:textColor="@color/textSecondary"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>

            <Spinner
                android:id="@+id/spEmoji"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@color/bgInput"
                android:padding="8dp"
                android:textColor="@color/textPrimary"
                android:layout_marginBottom="14dp"/>

            <!-- Product Name -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/InputField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Product Name"
                android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:textColor="@color/textPrimary"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- JioMart URL -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/InputField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="JioMart URL (https://…)"
                android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textUri"
                    android:textColor="@color/textPrimary"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Location Name -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/InputField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Location Name (e.g. Near My Home)"
                android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etLocationName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:textColor="@color/textPrimary"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Lat / Lon row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="12dp">

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/InputField"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Latitude"
                    android:layout_marginEnd="6dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etLat"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal|numberSigned"
                        android:textColor="@color/textPrimary"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/InputField"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Longitude"
                    android:layout_marginStart="6dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etLon"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal|numberSigned"
                        android:textColor="@color/textPrimary"/>
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <!-- Coord hint -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💡 Get coordinates from Google Maps → long-press your location → copy lat,lon"
                android:textColor="@color/textHint"
                android:textSize="11sp"
                android:lineSpacingExtra="2dp"
                android:layout_marginBottom="20dp"/>

            <!-- Save button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                style="@style/BtnSave"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="✅  Save Product"
                android:textSize="15sp"/>

        </LinearLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
