<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/alarmBg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="28dp">

        <!-- Pulse ring -->
        <View
            android:layout_width="130dp"
            android:layout_height="130dp"
            android:background="@drawable/bg_alarm_pulse"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="4dp"/>

        <!-- Big Emoji -->
        <TextView
            android:id="@+id/tvAlarmEmoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="-96dp"
            android:layout_gravity="center"
            android:text="📦"
            android:textSize="58sp"
            android:gravity="center"/>

        <View android:layout_width="0dp" android:layout_height="16dp"/>

        <!-- IN STOCK badge -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚨  IN STOCK!"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/colorInStock"
            android:layout_marginTop="16dp"
            android:gravity="center"/>

        <!-- Product name -->
        <TextView
            android:id="@+id/tvAlarmProduct"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/textPrimary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:maxLines="3"
            android:ellipsize="end"/>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="16dp"/>

        <!-- Location -->
        <TextView
            android:id="@+id/tvAlarmLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/textSecondary"
            android:textSize="14sp"
            android:gravity="center"/>

        <!-- Stores -->
        <TextView
            android:id="@+id/tvAlarmStores"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/textSecondary"
            android:textSize="13sp"
            android:gravity="center"/>

        <!-- Qty + Price row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="14dp">

            <TextView
                android:id="@+id/tvAlarmQty"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/colorAccent"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center"/>

            <TextView
                android:id="@+id/tvAlarmPrice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/colorInStock"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center"/>

        </LinearLayout>

        <!-- Countdown -->
        <TextView
            android:id="@+id/tvCountdown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="@color/textHint"
            android:textSize="12sp"
            android:gravity="center"
            android:text="Auto-dismiss in  05:00"/>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"/>

        <!-- Buy Now button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAlarmBuy"
            style="@style/BtnAlarmBuy"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="🛒  Buy Now on JioMart"
            android:textSize="15sp"/>

        <!-- Dismiss button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAlarmDismiss"
            style="@style/BtnDismiss"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:text="✕  Dismiss Alarm"
            android:textSize="15sp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:textColor="@color/textHint"
            android:textSize="11sp"
            android:gravity="center"
            android:text="Dr. Dev || Dr. Hamza  ·  @drdevhacks"/>

    </LinearLayout>
</ScrollView>
