<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.JioMartMonitor" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryVariant</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorOnSecondary">@color/bgApp</item>
        <item name="android:windowBackground">@color/bgApp</item>
        <item name="android:statusBarColor">@color/bgToolbar</item>
        <item name="android:navigationBarColor">@color/bgApp</item>
        <item name="android:textColorPrimary">@color/textPrimary</item>
        <item name="android:textColorSecondary">@color/textSecondary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="Theme.JioMartMonitor.Alarm" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/alarmBg</item>
        <item name="android:statusBarColor">@color/alarmBg</item>
        <item name="android:navigationBarColor">@color/alarmBg</item>
    </style>

    <!-- Full-screen transparent dialog for developer / expired dialogs -->
    <style name="DeveloperDialogTheme" parent="Theme.MaterialComponents.DayNight.Dialog">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowAnimationStyle">@style/DialogFadeAnim</item>
        <item name="colorSurface">@color/devDialogBg</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <style name="DialogFadeAnim">
        <item name="android:windowEnterAnimation">@android:anim/fade_in</item>
        <item name="android:windowExitAnimation">@android:anim/fade_out</item>
    </style>

    <style name="ToolbarStyle" parent="Widget.AppCompat.Toolbar">
        <item name="android:background">@color/bgToolbar</item>
        <item name="titleTextColor">@color/textPrimary</item>
    </style>

    <style name="ProductCard">
        <item name="cardCornerRadius">18dp</item>
        <item name="cardElevation">6dp</item>
        <item name="android:layout_marginStart">12dp</item>
        <item name="android:layout_marginEnd">12dp</item>
        <item name="android:layout_marginBottom">10dp</item>
    </style>

    <style name="BtnBuy" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/colorInStock</item>
        <item name="android:textColor">@color/bgApp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
    </style>

    <style name="BtnDismiss" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/alarmDismiss</item>
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">14dp</item>
    </style>

    <style name="BtnAlarmBuy" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/alarmBuy</item>
        <item name="android:textColor">@color/bgApp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">14dp</item>
    </style>

    <style name="BtnSave" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/colorPrimary</item>
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">14dp</item>
    </style>

    <style name="BtnDelete" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/colorOutOfStock</item>
        <item name="android:textColor">@color/colorOutOfStock</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="BtnEdit" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/colorSecondary</item>
        <item name="android:textColor">@color/colorSecondary</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="InputField" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/bgInput</item>
        <item name="boxStrokeColor">@color/colorPrimaryVariant</item>
        <item name="hintTextColor">@color/textSecondary</item>
        <item name="android:textColorHint">@color/textHint</item>
    </style>

</resources>
