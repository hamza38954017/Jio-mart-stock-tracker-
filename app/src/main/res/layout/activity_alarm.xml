<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/alarmBg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="32dp"
        android:paddingBottom="32dp">

        <!-- ── Pulse ring + Emoji ── -->
        <FrameLayout
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp">

            <View
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:background="@drawable/bg_alarm_pulse"/>

            <TextView
                android:id="@+id/tvAlarmEmoji"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="📦"
                android:textSize="62sp"
                android:gravity="center"/>
        </FrameLayout>

        <!-- ── IN STOCK badge ── -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_stock_badge"
            android:paddingHorizontal="20dp"
            android:layout_marginBottom="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚨"
                android:textSize="18sp"
                android:layout_marginEnd="8dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IN STOCK NOW!"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/colorInStock"
                android:letterSpacing="0.05"/>
        </LinearLayout>

        <!-- ── Product name ── -->
        <TextView
            android:id="@+id/tvAlarmProduct"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:maxLines="3"
            android:ellipsize="end"
            android:layout_marginBottom="24dp"
            android:lineSpacingExtra="4dp"/>

        <!-- ── Details card ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="#0E1829"
            app:cardElevation="8dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Location row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_info_row"
                    android:paddingHorizontal="14dp"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📍"
                        android:textSize="16sp"
                        android:layout_marginEnd="10dp"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Location"
                            android:textColor="@color/textHint"
                            android:textSize="10sp"/>
                        <TextView
                            android:id="@+id/tvAlarmLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/textSecondary"
                            android:textSize="13sp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Store IDs row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_info_row"
                    android:paddingHorizontal="14dp"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏪"
                        android:textSize="16sp"
                        android:layout_marginEnd="10dp"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Available Stores"
                            android:textColor="@color/textHint"
                            android:textSize="10sp"/>
                        <TextView
                            android:id="@+id/tvAlarmStores"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/textSecondary"
                            android:textSize="13sp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Qty + Price row (side by side) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_info_row"
                        android:paddingHorizontal="14dp"
                        android:layout_marginEnd="6dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📦"
                            android:textSize="16sp"
                            android:layout_marginEnd="8dp"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Quantity"
                                android:textColor="@color/textHint"
                                android:textSize="10sp"/>
                            <TextView
                                android:id="@+id/tvAlarmQty"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/colorAccent"
                                android:textSize="14sp"
                                android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_info_row"
                        android:paddingHorizontal="14dp"
                        android:layout_marginStart="6dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💰"
                            android:textSize="16sp"
                            android:layout_marginEnd="8dp"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Price"
                                android:textColor="@color/textHint"
                                android:textSize="10sp"/>
                            <TextView
                                android:id="@+id/tvAlarmPrice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/colorInStock"
                                android:textSize="14sp"
                                android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Product URL row (tappable) -->
                <LinearLayout
                    android:id="@+id/rowProductUrl"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_info_row"
                    android:paddingHorizontal="14dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔗"
                        android:textSize="16sp"
                        android:layout_marginEnd="10dp"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Product URL"
                            android:textColor="@color/textHint"
                            android:textSize="10sp"/>
                        <TextView
                            android:id="@+id/tvAlarmUrl"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tap to open in browser"
                            android:textColor="@color/colorSecondary"
                            android:textSize="12sp"
                            android:maxLines="1"
                            android:ellipsize="end"/>
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="↗"
                        android:textSize="14sp"
                        android:textColor="@color/colorSecondary"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Countdown ── -->
        <TextView
            android:id="@+id/tvCountdown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/textHint"
            android:textSize="12sp"
            android:gravity="center"
            android:text="Auto-dismiss in  05:00"
            android:layout_marginBottom="20dp"/>

        <!-- ── Buy Now button ── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAlarmBuy"
            style="@style/BtnAlarmBuy"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="🛒  Buy Now on JioMart"
            android:textSize="16sp"
            android:layout_marginBottom="12dp"/>

        <!-- ── Dismiss button ── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAlarmDismiss"
            style="@style/BtnDismiss"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="✕  Dismiss Alarm"
            android:textSize="14sp"
            android:layout_marginBottom="20dp"/>

        <!-- Footer -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/textHint"
            android:textSize="10sp"
            android:gravity="center"
            android:text="Dr. Dev  ·  Dr. Hamza  ·  @drdevhacks"/>

    </LinearLayout>
</ScrollView>
