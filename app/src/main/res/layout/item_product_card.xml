<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card"
    style="@style/ProductCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/bgCard">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/card_padding">

        <!-- Row 1: Dot + Emoji + Name + Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:id="@+id/statusDot"
                android:layout_width="@dimen/dot_size"
                android:layout_height="@dimen/dot_size"
                android:background="@drawable/dot_grey"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tvEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📦"
                android:textSize="@dimen/text_emoji"
                android:layout_marginEnd="10dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Product name — becomes a tappable JioMart link when in stock -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/textPrimary"
                        android:textSize="@dimen/text_title"
                        android:textStyle="bold"
                        android:maxLines="2"
                        android:ellipsize="end"/>

                    <!-- JioMart link icon — shown only when in stock -->
                    <TextView
                        android:id="@+id/tvJioMartIcon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:text=" ↗"
                        android:textSize="13sp"
                        android:textColor="#66BB6A"
                        android:textStyle="bold"
                        android:visibility="gone"/>

                </LinearLayout>

                <!-- "Open in JioMart" chip — shown only when in stock -->
                <TextView
                    android:id="@+id/tvOpenJiomart"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:text="🛒 Open in JioMart →"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:background="@drawable/bg_jiomart_chip"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:text="⏳  CHECKING…"
                    android:textColor="@color/colorChecking"/>

            </LinearLayout>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"/>

        <!-- Row 2: Location + Stores -->
        <TextView
            android:id="@+id/tvLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/textSecondary"
            android:textSize="@dimen/text_body"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/tvStores"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/textSecondary"
            android:textSize="@dimen/text_body"/>

        <!-- Row 3: Qty + Price -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tvQty"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/colorAccent"
                android:textSize="@dimen/text_body"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/colorInStock"
                android:textSize="@dimen/text_body"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- Row 4: Last checked -->
        <TextView
            android:id="@+id/tvChecked"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/textHint"
            android:textSize="@dimen/text_caption"/>

        <!-- Row 5: Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEdit"
                style="@style/BtnEdit"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="✏️ Edit"
                android:textSize="11sp"
                android:layout_marginEnd="6dp"
                android:visibility="gone"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDelete"
                style="@style/BtnDelete"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="🗑️ Remove"
                android:textSize="11sp"
                android:layout_marginEnd="6dp"
                android:visibility="gone"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBuy"
                style="@style/BtnBuy"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="🛒 Buy Now"
                android:textSize="11sp"
                android:visibility="gone"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
